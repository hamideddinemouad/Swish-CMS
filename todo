PATCH /api/pages/:pageName/component/content
body: { data: fullDataObject }
usage: axios.patch(`/api/pages/${pageName}/component/content`, { data: fullDataObject }, { withCredentials: true })
effect: replaces whole component.data

PATCH /api/pages/:pageName/component/preference
body: { preference: fullPreferenceObject }
usage: axios.patch(`/api/pages/${pageName}/component/preference`, { preference: fullPreferenceObject }, { withCredentials: true })
effect: replaces whole component.preference

GET /api/pages/by-tenant
body: none
usage: axios.get(`/api/pages/by-tenant`, { withCredentials: true })
effect: returns all pages for the authenticated tenant

PATCH /api/pages/:pageName/components/:componentType/disable
body: none
usage: axios.patch(`/api/pages/${pageName}/components/${componentType}/disable`, {}, { withCredentials: true })
effect: sets enabled=false in pages.components for the matching type

DELETE /api/pages/by-name/:pageName
body: none
usage: axios.delete(`/api/pages/by-name/${pageName}`, { withCredentials: true })
effect: deletes page; related component row is removed by cascade

